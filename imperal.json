                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Default row for apps without their own setting (bell/telegram/email)",
            "title": "Default Channels"
          },
          "app_id": {
            "default": "",
            "description": "App to change (e.g. mail, sharelock-v2, automations, system)",
            "title": "App Id",
            "type": "string"
          },
