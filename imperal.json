    {
      "name": "set_preferences",
      "description": "Change notification routing: global on/off, the default row, or one app's channels ([] = mute).",
      "action_type": "write",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "description": "Exactly ONE of: enabled (global switch) | default_channels (default row)\n| app_id+channels (one app's row; empty channels = mute that app).",
